# =============================================================================
# カタヅケ Backend — 環境変数テンプレート
# このファイルを backend/.env にコピーして値を埋めること。
# .env は .gitignore 対象。絶対にコミットしない。
# =============================================================================

# -----------------------------------------------------------------------------
# データベース（必須）
# -----------------------------------------------------------------------------
# asyncpg ドライバを使用。
# Docker Compose 経由の場合: ホスト名は "db"（サービス名）に変わる。
# ローカル直接起動の場合: "localhost" のまま使用。
DATABASE_URL=postgresql+asyncpg://assetwise:assetwise@localhost:5432/assetwise

# -----------------------------------------------------------------------------
# Google AI Studio API キー（Gemini Vision 用 / Phase 3 以降で必須）
# -----------------------------------------------------------------------------
# https://aistudio.google.com/app/apikey から無料取得
GOOGLE_API_KEY=AIza...

# -----------------------------------------------------------------------------
# デバッグ設定（任意）
# -----------------------------------------------------------------------------
# true にすると SQLAlchemy が発行する全 SQL を stdout に出力する（本番は false 推奨）
SQL_ECHO=false


# -----------------------------------------------------------------------------
# カタヅケ クローズドβ（認証 / ストレージ / メール）
# -----------------------------------------------------------------------------
# JWT 署名鍵。本番は Render の generateValue で自動設定済み
JWT_SECRET=change-me-to-random-64-hex
JWT_EXPIRE_MINUTES=10080
# この email で signup したユーザーが admin になる
ADMIN_EMAILS=ko.13.hei@gmail.com
# 写真保存先（Render Free はエフェメラル）
STORAGE_DIR=./uploads_storage
# Brevo メール通知（未設定なら送信スキップ）
BREVO_API_KEY=
MAIL_FROM=noreply@katadzuke.jp
MAIL_FROM_NAME=カタヅケ
FRONTEND_BASE_URL=http://localhost:3000
# 機微データ（振込先口座情報等）の対称鍵暗号化キー（Fernet, urlsafe base64 32byte）。
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 未設定時は operator_applications の口座暗号化・復号でエラーになる（起動時ではなく呼び出し時に落ちる）。
APP_ENCRYPTION_KEY=
# LINE Messaging API のチャネルアクセストークン（Push通知送信用。未設定なら送信スキップ）
LINE_CHANNEL_ACCESS_TOKEN=
# LINE Login チャネル ID（フロントの LINE_CLIENT_ID と同一値）。
# /auth/line/exchange でアクセストークンの発行元チャネル検証に使用。未設定時はLINEログインを503で拒否する。
LINE_CLIENT_ID=
# 実行環境（development | production）。本番は必ず production を設定すること
# （production かつ JWT_SECRET が未設定のデフォルト値のままだと起動時にエラーで落ちる）。
APP_ENV=development
# CORSで許可するオリジン（カンマ区切り）。未設定時は FRONTEND_BASE_URL と localhost:3000/3100 を許可する。
ALLOWED_ORIGINS=
