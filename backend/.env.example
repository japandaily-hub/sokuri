# =============================================================================
# AssetWise Backend — 環境変数テンプレート
# このファイルを backend/.env にコピーして値を埋めること。
# .env は .gitignore 対象。絶対にコミットしない。
# =============================================================================

# -----------------------------------------------------------------------------
# データベース（必須）
# -----------------------------------------------------------------------------
# asyncpg ドライバを使用。
# Docker Compose 経由の場合: ホスト名は "db"（サービス名）に変わる。
# ローカル直接起動の場合: "localhost" のまま使用。
DATABASE_URL=postgresql+asyncpg://assetwise:assetwise@localhost:5432/assetwise

# -----------------------------------------------------------------------------
# Google AI Studio API キー（Gemini Vision 用 / Phase 3 以降で必須）
# -----------------------------------------------------------------------------
# https://aistudio.google.com/app/apikey から無料取得
GOOGLE_API_KEY=AIza...

# -----------------------------------------------------------------------------
# デバッグ設定（任意）
# -----------------------------------------------------------------------------
# true にすると SQLAlchemy が発行する全 SQL を stdout に出力する（本番は false 推奨）
SQL_ECHO=false


# -----------------------------------------------------------------------------
# カタヅケ クローズドβ（認証 / ストレージ / メール）
# -----------------------------------------------------------------------------
# JWT 署名鍵。本番は Render の generateValue で自動設定済み
JWT_SECRET=change-me-to-random-64-hex
JWT_EXPIRE_MINUTES=10080
# この email で signup したユーザーが admin になる
ADMIN_EMAILS=ko.13.hei@gmail.com
# 写真保存先（Render Free はエフェメラル）
STORAGE_DIR=./uploads_storage
# Brevo メール通知（未設定なら送信スキップ）
BREVO_API_KEY=
MAIL_FROM=noreply@katadzuke.jp
MAIL_FROM_NAME=カタヅケ
FRONTEND_BASE_URL=http://localhost:3000
